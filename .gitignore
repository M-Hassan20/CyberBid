# Backend ignore
/backend/node_modules
/backend/.env
/backend/.env.local
/backend/.env.development.local
/backend/.env.test.local
/backend/.env.production.local
/backend/dist
/backend/coverage
/backend/logs
/backend/*.log

# Frontend ignore
/frontend/node_modules
/frontend/.env
/frontend/.env.local
/frontend/.env.development.local
/frontend/.env.test.local
/frontend/.env.production.local
/frontend/build
/frontend/dist
/frontend/coverage
/frontend/*.log

# Common ignore patterns
.DS_Store
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache